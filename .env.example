# Mini-OpenClaw Configuration
# Copy this file to .env and fill in your values.

# ---------------------------------------------------------------------------
# LLM provider selection
# ---------------------------------------------------------------------------
# Which backend the planner uses. Allowed values: "anthropic" or "gemini".
# Default: anthropic.
LLM_PROVIDER=anthropic

# ---------------------------------------------------------------------------
# Anthropic (Claude) — required when LLM_PROVIDER=anthropic
# ---------------------------------------------------------------------------
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ---------------------------------------------------------------------------
# Google Gemini — required when LLM_PROVIDER=gemini
# ---------------------------------------------------------------------------
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=gemini-2.5-flash

# --- Vertex AI mode (use GCP credits instead of AI Studio API key) ---
# Set VERTEX_AI=true and provide your GCP project.
# Auth: run `gcloud auth application-default login` first.
# VERTEX_AI=true
# GCP_PROJECT=your-gcp-project-id
# GCP_LOCATION=us-central1

# ---------------------------------------------------------------------------
# Ollama (local models) — no API key needed
# ---------------------------------------------------------------------------
# Install Ollama (https://ollama.ai), then: ollama pull llama3.2
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# ---------------------------------------------------------------------------
# Optional: workspace and storage
# ---------------------------------------------------------------------------
# WORKSPACE_ROOT=./workspace

# Named mounts — extra directories the agent can access.
# JSON array of {name, path, read_only} objects.
# Tools address them with a "name:" prefix, e.g. read_file("notes:todo.md").
# WORKSPACE_MOUNTS='[{"name":"notes","path":"/home/me/notes","read_only":true}]'
# DATABASE_PATH=./mini_openclaw.db

# ---------------------------------------------------------------------------
# Optional: server settings
# ---------------------------------------------------------------------------
# BACKEND_PORT=8000
# FRONTEND_PORT=5173
# LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Optional: ReAct loop settings
# ---------------------------------------------------------------------------
# Use the iterative ReAct loop (true) or the legacy plan-and-execute path (false).
# USE_REACT=true
# Maximum number of think→act→observe iterations before the agent stops.
# REACT_MAX_ITERATIONS=10
# Block after N consecutive identical tool+args calls (loop detection). Minimum: 2.
# REACT_DUPLICATE_CAP=3
# Generate a goal checklist before the ReAct loop starts (hybrid Plan→ReAct).
# REACT_USE_GOALS=false
# Maximum number of mid-loop replans (0 = goals only, no replanning). Clamped to 0–5.
# REACT_MAX_REPLANS=2
# Warn the LLM when this percentage of the iteration budget remains. Clamped to 10–80.
# REACT_BUDGET_WARN_PCT=30
# Max files allowed in a single batch read_file call.
# REACT_READ_FILE_MAX_BATCH=10
# Max total output characters from a read_file tool call (before planner truncation).
# REACT_READ_FILE_MAX_CHARS=50000
# Max characters kept per tool observation when fed back to the planner.
# Applies to all tools except read_file. Increase if search_in_files or
# run_shell_safe results are being truncated and the agent misses data.
# REACT_OBSERVATION_MAX_CHARS=1000
# Max characters kept per read_file observation when fed back to the planner.
# Single = one file read; batch = per-file limit in a multi-file read.
# Increase if the planner's final answer is missing file content.
# REACT_READ_FILE_OBS_SINGLE=3000
# REACT_READ_FILE_OBS_BATCH=2000

# ---------------------------------------------------------------------------
# Optional: Context window management
# ---------------------------------------------------------------------------
# Override the auto-detected context window size (in tokens). 0 = auto-detect
# from the model name. Useful for testing compression with large models like
# Claude (200K) — set to e.g. 4096 to simulate a constrained context window.
# CONTEXT_WINDOW_OVERRIDE=0

# ---------------------------------------------------------------------------
# Optional: Self-Reflection
# ---------------------------------------------------------------------------
# Critique the agent's final answer before delivering it. When enabled and the
# quality score is below threshold, the agent re-enters the ReAct loop to take
# corrective action (call more tools, re-read files, etc.). If no iteration
# budget remains, falls back to a text-only rewrite.
# REACT_SELF_REFLECT=true
# REACT_REFLECT_QUALITY_THRESHOLD=0.7

# ---------------------------------------------------------------------------
# Optional: Memory summary settings
# ---------------------------------------------------------------------------
# Auto-generate a conversation summary every N completed runs. Set to 0 to disable.
# SUMMARY_INTERVAL=5
# Maximum number of summaries to keep. Oldest are pruned when exceeded.
# MAX_SUMMARIES=3

# ---------------------------------------------------------------------------
# Optional: Agent Dreams (memory consolidation)
# ---------------------------------------------------------------------------
# Dream every N episodes to extract strategies and preferences. 0 = disabled.
# Insights are proposed for user review before influencing the planner.
# DREAM_INTERVAL=5
# Maximum active strategies/preferences to keep. Lowest-confidence item is
# evicted when a new one is accepted and the cap is reached.
# DREAM_MAX_STRATEGIES=10
# DREAM_MAX_PREFERENCES=10
# Minimum LLM confidence score (0.0-1.0) for a dream insight to be proposed.
# DREAM_CONFIDENCE_THRESHOLD=0.6

# ── Sub-agent delegation ──────────────────────────────
# Enable/disable the delegate_task tool.
# DELEGATE_ENABLED=true
# Require user approval before spawning a child run (true = safer, false = smoother).
# DELEGATE_APPROVAL_REQUIRED=true
# Maximum nesting depth (0 = parent can't delegate, 1 = one level, 2 = grandchildren).
# DELEGATE_MAX_DEPTH=2
# Maximum child runs a single parent can spawn.
# DELEGATE_MAX_CHILDREN=3
# Iteration cap per child run (hard max regardless of what the agent requests).
# DELEGATE_MAX_CHILD_ITERATIONS=5

# ── Task scheduler ────────────────────────────────────
# Enable/disable the scheduled task system and its schedule_task tool.
# SCHEDULER_ENABLED=true
# Maximum number of active scheduled tasks allowed at once.
# SCHEDULER_MAX_TASKS=20

# ── Web fetch (runtime URL fetching) ─────────────────
# Enable the fetch_url tool for live web data (weather, APIs, docs).
# WEB_FETCH_ENABLED=true
# Allowed domains — EMPTY list blocks everything (opt-in by design).
# Add domains the agent may fetch from. Subdomains are included automatically.
# JSON array, e.g.: WEB_FETCH_ALLOWED_DOMAINS='["api.open-meteo.com"]'
# WEB_FETCH_ALLOWED_DOMAINS=[]
# Maximum response size in bytes (default 1MB).
# WEB_FETCH_MAX_BYTES=1048576
# Request timeout in seconds.
# WEB_FETCH_TIMEOUT_SECONDS=10.0
# Maximum HTTP redirects to follow.
# WEB_FETCH_MAX_REDIRECTS=3

# ── MCP client (consume external MCP tool servers) ───
# Connect to external MCP servers and expose their tools to the agent.
# OFF by default — existing behavior is unchanged unless explicitly enabled.
# MCP_CLIENT_ENABLED=false
#
# JSON array of server configurations. Each entry needs:
#   name      — short alias (alphanumeric/underscore), used to namespace tools
#   transport — "stdio" | "sse" | "streamable_http"
#   command   — executable to launch (required for stdio)
#   args      — arguments list (stdio only)
#   url       — server URL (required for sse/streamable_http)
#   enabled   — true/false (default true)
#   approval_required — require user approval for this server's tools (default true)
#   allowed_tools — optional allowlist of tool names (empty = all tools)
#
# Tools are namespaced as mcp__{server_name}__{tool_name}.
# All MCP tools default to RiskLevel.HIGH with approval required.
# A failing server is skipped at startup (never crashes the agent).
#
# Examples:
# MCP_SERVERS='[{"name":"fs","transport":"stdio","command":"npx","args":["-y","@anthropic/mcp-filesystem","/tmp/safe"]}]'
# MCP_SERVERS='[{"name":"weather","transport":"sse","url":"http://localhost:3001/sse"}]'
