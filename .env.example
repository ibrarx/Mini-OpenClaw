# Mini-OpenClaw Configuration
# Copy this file to .env and fill in your values.

# Anthropic (Optional if Gemini is set)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Gemini (Optional if Anthropic is set)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional: workspace directory (default: ./workspace)
# WORKSPACE_ROOT=./workspace

# Optional: database file path (default: ./mini_openclaw.db)
# DATABASE_PATH=./mini_openclaw.db

# Optional: model override
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: server settings
# BACKEND_PORT=8000
# FRONTEND_PORT=5173
# LOG_LEVEL=INFO
