# Mini-OpenClaw Configuration
# Copy this file to .env and fill in your values.

# ---------------------------------------------------------------------------
# LLM provider selection
# ---------------------------------------------------------------------------
# Which backend the planner uses. Allowed values: "anthropic" or "gemini".
# Default: anthropic.
LLM_PROVIDER=anthropic

# ---------------------------------------------------------------------------
# Anthropic (Claude) — required when LLM_PROVIDER=anthropic
# ---------------------------------------------------------------------------
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ---------------------------------------------------------------------------
# Google Gemini — required when LLM_PROVIDER=gemini
# ---------------------------------------------------------------------------
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=gemini-2.5-flash

# ---------------------------------------------------------------------------
# Optional: workspace and storage
# ---------------------------------------------------------------------------
# WORKSPACE_ROOT=./workspace
# DATABASE_PATH=./mini_openclaw.db

# ---------------------------------------------------------------------------
# Optional: server settings
# ---------------------------------------------------------------------------
# BACKEND_PORT=8000
# FRONTEND_PORT=5173
# LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Optional: ReAct loop settings
# ---------------------------------------------------------------------------
# Use the iterative ReAct loop (true) or the legacy plan-and-execute path (false).
# USE_REACT=true
# Maximum number of think→act→observe iterations before the agent stops.
# Internally capped at 25 to prevent runaway API costs.
# REACT_MAX_ITERATIONS=10
# Block after N consecutive identical tool+args calls (loop detection). Minimum: 2.
# REACT_DUPLICATE_CAP=3

# ---------------------------------------------------------------------------
# Optional: Memory summary settings
# ---------------------------------------------------------------------------
# Auto-generate a conversation summary every N completed runs. Set to 0 to disable.
# SUMMARY_INTERVAL=5
# Maximum number of summaries to keep. Oldest are pruned when exceeded.
# MAX_SUMMARIES=3
