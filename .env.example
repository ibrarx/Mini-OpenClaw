# Mini-OpenClaw Configuration
# Copy this file to .env and fill in your values.

# Anthropic (Optional if Gemini is set)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Gemini (Optional if Anthropic is set)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Database
# For local dev, leave DATABASE_URL empty to use SQLite.
# For Docker, docker-compose will set DATABASE_URL automatically.
DATABASE_URL=
DATABASE_PATH=./mini_openclaw.db

# Postgres (used by Docker)
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=mini_openclaw

# Optional: server settings
# BACKEND_PORT=8000
# FRONTEND_PORT=5173
# LOG_LEVEL=INFO
