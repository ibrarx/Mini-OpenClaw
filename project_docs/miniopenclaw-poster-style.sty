\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{miniopenclaw-poster-style}[2026/06/01 Reusable poster styling]

% Theme colors: change these three values to quickly adapt the poster palette.
\definecolor{posterblue}{HTML}{174A7C}
\definecolor{posterlight}{HTML}{EAF2F8}
\definecolor{postergray}{HTML}{F5F5F5}

\newcommand{\PosterSetupColors}[3]{%
  \definecolor{posterblue}{HTML}{#1}%
  \definecolor{posterlight}{HTML}{#2}%
  \definecolor{postergray}{HTML}{#3}%
}

% Theme typography and spacing: redefine these commands in main.tex if needed.
\newcommand{\PosterTitleFont}{\Huge\bfseries}
\newcommand{\PosterAuthorFont}{\Large}
\newcommand{\PosterMetaFont}{\large}
\newcommand{\PosterBlockTitleFont}{\Large\bfseries}
\newcommand{\PosterBlockTextWidth}{\dimexpr\linewidth-1.4cm\relax}
\newcommand{\PosterBlockInnerXSep}{0.6cm}
\newcommand{\PosterBlockInnerYSep}{0.45cm}
\newcommand{\PosterBlockCornerRadius}{4pt}
\newcommand{\PosterBlockTopBottomSpace}{0.25cm}

\newcommand{\SectionIcon}[1]{%
  \tikz[baseline=-0.6ex]\node[circle, fill=posterblue, text=white, inner sep=1.8pt, minimum size=1.45em, font=\scriptsize]{\faIcon{#1}};%
}

\newcommand{\PosterTitle}[4]{%
  \begin{flushleft}
    {\color{posterblue}\PosterTitleFont #1\par}
    \vspace{0.4cm}
    {\PosterAuthorFont #2\par}
    \vspace{0.2cm}
    {\PosterMetaFont #3\par}
    \vspace{0.2cm}
    {\PosterMetaFont #4\par}
  \end{flushleft}
  \vspace{0.6cm}
}

\newcommand{\PosterPageTitle}[1]{%
  \begin{center}
    {\color{posterblue}\PosterTitleFont #1\par}
  \end{center}
  \vspace{0.4cm}
}

\newcommand{\PosterBlock}[2]{%
  \vspace{\PosterBlockTopBottomSpace}
  \noindent
  \begin{tikzpicture}
    \node[
      fill=posterlight,
      rounded corners=\PosterBlockCornerRadius,
      text width=\PosterBlockTextWidth,
      inner xsep=\PosterBlockInnerXSep,
      inner ysep=\PosterBlockInnerYSep,
      align=left
    ] {
      {\color{posterblue}\PosterBlockTitleFont #1}\par\vspace{0.2cm}
      #2
    };
  \end{tikzpicture}
  \vspace{\PosterBlockTopBottomSpace}
}